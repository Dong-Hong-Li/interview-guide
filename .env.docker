# 仅给「docker compose 里的 server 容器」使用：在 env_file 中晚于 .env 加载，覆盖宿主机联调用连接串。
# 可提交到 Git（不含 API 密钥）；若你改了 .env 里的 POSTGRES_PASSWORD，请同步改下面的 DATABASE_URL。
# 本机 `go run` / VS Code 调试只读 .env，不会自动加载本文件。

POSTGRES_HOST=postgres
DATABASE_URL=postgres://postgres:123456@postgres:5432/interview-guide?sslmode=disable
REDIS_HOST=redis
APP_STORAGE_ENDPOINT=http://rustfs:9000
