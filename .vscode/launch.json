{
    "version": "0.2.0",
    "configurations": [
        {
            // 本机 Delve 监听 SERVER_PORT（默认 8080）。Vite 默认代理到 8081（compose 里的容器），
            // 若不改前端代理，请求仍打到旧容器 → 例如导出 PDF 会一直 501。
            // 请在 interview-guide/.env.development 设置：VITE_DEV_PROXY_TARGET=http://127.0.0.1:8080
            // 或临时停掉占用 8081 的容器后，把此处改为 "8081" 与 vite 默认一致。
            "name": "Interview Guide Go Take Notes - 本机调试，依赖 Docker 起基础设施",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "cwd": "${workspaceFolder}/interview-guide-go-take-notes",
            "program": "${workspaceFolder}/interview-guide-go-take-notes/cmd/server",
            "envFile": "${workspaceFolder}/.env",
            "env": {
                "AI_MODEL": "kimi-k2.6",
                "SERVER_PORT": "8080",
                "POSTGRES_HOST": "localhost",
                "POSTGRES_PORT": "5432",
                "POSTGRES_USER": "postgres",
                "POSTGRES_PASSWORD": "123456",
                "POSTGRES_DB": "interview-guide",
                "REDIS_HOST": "localhost",
                "REDIS_PORT": "6379",
                "APP_STORAGE_ENDPOINT": "http://127.0.0.1:19000",
                "APP_STORAGE_ACCESS_KEY": "rustfsadmin",
                "APP_STORAGE_SECRET_KEY": "rustfsadmin",
                "APP_STORAGE_BUCKET": "interview-guide",
                "APP_STORAGE_REGION": "us-east-1"
            }
        }
    ]
}