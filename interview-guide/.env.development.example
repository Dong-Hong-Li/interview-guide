# 复制为 .env.development 后按需二选一（改完须重启 pnpm dev）：
#   cp .env.development.example .env.development

# A) VS Code / Delve 本机调试 Go（launch.json 默认 SERVER_PORT=8080）
VITE_DEV_PROXY_TARGET=http://127.0.0.1:8080

# B) 只跑 Docker 里的 Go（compose 宿主机一般为 8081）→ 注释掉 A，启用下面一行：
# VITE_DEV_PROXY_TARGET=http://127.0.0.1:8081

# 可选：不走代理、直连后端（一般留空）
# VITE_API_BASE_URL=http://127.0.0.1:8080
