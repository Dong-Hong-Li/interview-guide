# 仓库根目录 .env 的示例副本：复制为 `.env` 后按需填写真实值。
# docker compose 会读取 `.env`，用于 compose.yaml 中的 ${VAR} 插值。
# 请勿将含真实密钥的 .env 提交到 Git（根目录 .gitignore 已忽略 .env）。
#
# 以下变量与 interview-guide-go/internal/config 中校验一致：
# 未标注「可选」的均为 LoadEnvironmentVariables 时必填（缺失即进程退出）。

# ---------- HTTP 服务（必填）----------
# 可选：单独 docker run 且使用挂载 .env 时，在命令行设 ENV_FILE=/config/.env 并 -v 宿主 .env 到该路径（见 README.Docker.md）。
# ENV_FILE=/config/.env
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
# 读超时（秒），须为正整数
SERVER_READ_TIMEOUT_SECONDS=120
 
# ---------- PostgreSQL（必填）----------
# 与 compose 中 postgres 服务一致；本机 go run 时用 localhost
DATABASE_URL=postgres://postgres:<your-postgres-password>@localhost:5432/interview-guide?sslmode=disable
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=<your-postgres-password>
POSTGRES_DB=interview-guide
POSTGRES_SSLMODE=disable

# ---------- Redis（必填；密码可为空 = 无 AUTH，与 compose 默认 redis 一致）----------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ---------- 对象存储 S3 兼容（必填）----------
# 本机连 compose 里的 rustfs 映射端口 19000 → 容器 9000
APP_STORAGE_ENDPOINT=http://127.0.0.1:19000
APP_STORAGE_ACCESS_KEY=<your-s3-access-key>
APP_STORAGE_SECRET_KEY=<your-s3-secret-key>
APP_STORAGE_BUCKET=interview-guide
APP_STORAGE_REGION=us-east-1
# 预签名 GET 有效期（秒），须为正整数
APP_STORAGE_PRESIGN_GET_EXPIRES_SEC=3600

# ---------- 简历 / LLM（OpenAI 兼容，必填）----------
# Moonshot OpenAI 兼容端点。OPENAI / MOONSHOT 两变量均须非空，填【同一】平台 API Key
OPENAI_BASE_URL=https://api.moonshot.cn/v1
# model
AI_MODEL=kimi-k2.5
OPENAI_API_KEY=sk-<your-moonshot-api-key>
MOONSHOT_API_KEY=sk-<your-moonshot-api-key>
# 简历送入模型的正文上限（Unicode 字符数）、补全上限、温度（均须合法数值；temperature ≥ 0）
RESUME_AI_MAX_RUNES=120000
RESUME_AI_MAX_COMPLETION_TOKENS=32768
RESUME_AI_TEMPERATURE=1

# ---------- 浏览器跨域 CORS（必填）----------
# 逗号分隔 Origin；本地前端（Vite）示例如下；
# 若通过局域网 IP 打开 Vite（如 http://192.168.2.1:5173 / http://192.168.10.6:5173）：
#   1) 简单做法：直接把 Vite "Network" 提示的完整 Origin 都列进来；
#   2) 推荐做法：保留 localhost，再设 CORS_ALLOW_LAN_VITE_ORIGINS=1，
#      让后端自动合并 http://192.168.*:5173 与 http://10.*:5173（go-chi/cors 单星通配；生产勿开）。
CORS_ALLOWED_ORIGINS=http://localhost:5173
CORS_ALLOW_LAN_VITE_ORIGINS=1

# ---------- 知识库向量 Embeddings（必填）----------
# Moonshot 不提供 OpenAI 兼容的 POST /v1/embeddings，须使用 OpenAI 官方或其它兼容网关的专用 Key。
# 请将 KB_EMBEDDING_OPENAI_API_KEY 设为该平台密钥（勿复用 MOONSHOT_API_KEY）。
# 知识库 Embedding 专用密钥
KB_EMBEDDING_OPENAI_API_KEY=sk-<your-embedding-api-key>
# 知识库 Embedding 网关 Base URL
KB_EMBEDDING_OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# 向量模型
KB_EMBEDDING_MODEL=text-embedding-v4
# 向量维度
KB_EMBEDDING_DIMENSIONS=1536
# 知识库 AI 分片（Chat，OPENAI_BASE_URL）；单次输出上限 token。Moonshot kimi-k2.5 总窗口 256K：须 prompt_tokens+本值≤262144，否则会 400（可调小正文 KB_CHUNK_MAX_INPUT_RUNES）
KB_CHUNK_MAX_COMPLETION_TOKENS=262144
# 可选：启动知识库向量化消费者时作废 Redis PEL 积压（DB 置 FAILED + XACK），调试重启后可重新上传/入队
KB_VECTORIZE_ABORT_PENDING_ON_START=true

# ---------- Docker Compose：compose.yaml 仅通过本段变量插值（勿在 compose.yaml 写死值）----------
# 可选：HTTP 访问日志屏蔽
HTTP_ACCESS_LOG_SUPPRESS=GET@/api/interview/sessions/*,GET@/api/resumes/*/detail

# RustFS（S3 兼容）
RUSTFS_IMAGE=rustfs/rustfs:latest
RUSTFS_CONTAINER_NAME=rustfs_local
RUSTFS_PUBLISH_PORT_9000=19000
RUSTFS_PUBLISH_PORT_9001=19001
RUSTFS_DATA_HOST_PATH=/tmp/rustfs/data
RUSTFS_ACCESS_KEY=<your-rustfs-access-key>
RUSTFS_SECRET_KEY=<your-rustfs-secret-key>
RUSTFS_CONSOLE_ENABLE=true

# Postgres 镜像与宿主机端口、初始化 SQL 挂载路径（相对仓库根）
# DDL 仍共用 interview-guide-go 的 schema，直到 take-notes 目录下有独立 schema
POSTGRES_IMAGE=pgvector/pgvector:pg16
POSTGRES_PUBLISH_PORT=5432
POSTGRES_INIT_SCHEMA_REL_PATH=./interview-guide-go/internal/db/schema

# Redis 镜像与宿主机端口
REDIS_IMAGE=redis:7
REDIS_PUBLISH_PORT=6379

# server 镜像构建上下文与对外映射（容器内端口须与 SERVER_PORT 一致）
SERVER_BUILD_CONTEXT=./interview-guide-go
SERVER_DOCKERFILE=Dockerfile
SERVER_PUBLISH_PORT=8081
SERVER_CONTAINER_PORT=8080

# 简历上传单文件大小上限（须为十进制整数字节数，例如 20971520 = 20MiB）
MAX_RESUME_UPLOAD_BYTES=20971520
